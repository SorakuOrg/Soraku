# =============================================================================
#  SORAKU COMMUNITY — Web App Environment Variables
#  File  : apps/web/.env.example
#  Copy  : cp apps/web/.env.example apps/web/.env.local
#  Deploy: Vercel → Project soraku → Settings → Environment Variables
#
#  ⚠  JANGAN commit .env.local ke Git — sudah ada di .gitignore
#  ⚠  Semua perubahan ENV di Vercel butuh redeploy agar aktif
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# [1] SUPABASE  (WAJIB — platform tidak bisa jalan tanpa ini)
# ─────────────────────────────────────────────────────────────────────────────

# Project URL Supabase
# Ambil dari: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://jrgknsxqwuygcoocnnnb.supabase.co

# Anon key (aman untuk expose ke client)
# Ambil dari: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (RAHASIA — jangan expose ke client, server-side only)
# Ambil dari: Supabase Dashboard → Project Settings → API → service_role
# ⚠ Key ini bypass RLS — simpan dengan aman!
SUPABASE_SERVICE_ROLE_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# [2] URL APLIKASI  (WAJIB)
# ─────────────────────────────────────────────────────────────────────────────

# URL utama aplikasi — harus sama persis dengan Site URL di Supabase Auth
# Lokal : http://localhost:3000
# Prod  : https://soraku.vercel.app
NEXT_PUBLIC_SITE_URL=https://soraku.vercel.app

# Alias (dipakai di beberapa tempat, isi sama dengan SITE_URL)
NEXT_PUBLIC_APP_URL=https://soraku.vercel.app


# ─────────────────────────────────────────────────────────────────────────────
# [3] DISCORD  (WAJIB untuk OAuth & komunitas)
# ─────────────────────────────────────────────────────────────────────────────

# ID Discord user yang otomatis dapat role OWNER saat pertama kali login
# Cara ambil: Discord → aktifkan Developer Mode (Settings → Advanced)
#             klik kanan nama user → Copy User ID
# Bisa lebih dari satu, pisahkan koma: 123456,789012
OWNER_DISCORD_IDS=1020644780075659356

# Kode invite server Discord Soraku (tanpa discord.gg/)
# Tampil di tombol join Discord di website
DISCORD_INVITE_CODE=qm3XJvRa6B


# ─────────────────────────────────────────────────────────────────────────────
# [4] KOMUNIKASI WEB ↔ BOT  (WAJIB saat bot sudah deploy)
# ─────────────────────────────────────────────────────────────────────────────

# Secret untuk auth request dari web ke bot
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Harus SAMA dengan SORAKU_API_SECRET di services/bot/.env
SORAKU_API_SECRET=

# URL HTTP server bot (Railway)
# Isi setelah bot berhasil deploy ke Railway
# Format: https://<nama-project>.up.railway.app
BOT_WEBHOOK_URL=

# Secret untuk verifikasi request yang masuk dari bot ke web
# Harus SAMA dengan WEBHOOK_SECRET di services/bot/.env
BOT_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# [5] PAYMENT  (Opsional — aktifkan saat fitur donasi/premium live)
# ─────────────────────────────────────────────────────────────────────────────

# Xendit — payment gateway utama
# Ambil dari: Xendit Dashboard → Settings → API Keys → Secret Key
XENDIT_SECRET_KEY=

# Xendit webhook verification token
# Ambil dari: Xendit Dashboard → Settings → Webhooks → Verification Token
XENDIT_WEBHOOK_TOKEN=

# Trakteer — donasi via Trakteer.id
# Ambil dari: Trakteer Dashboard → Settings → Webhook → Secret
TRAKTEER_WEBHOOK_TOKEN=


# =============================================================================
#  CHECKLIST SETUP
# =============================================================================
#
#  Wajib diisi sebelum deploy:
#  ✅ NEXT_PUBLIC_SUPABASE_URL        — dari Supabase Dashboard
#  ✅ NEXT_PUBLIC_SUPABASE_ANON_KEY   — dari Supabase Dashboard
#  ✅ SUPABASE_SERVICE_ROLE_KEY       — dari Supabase Dashboard (RAHASIA!)
#  ✅ NEXT_PUBLIC_SITE_URL            — https://soraku.vercel.app
#  ✅ NEXT_PUBLIC_APP_URL             — sama dengan SITE_URL
#  ✅ OWNER_DISCORD_IDS               — Discord ID Riu (sudah ada: 1020644780075659356)
#  ✅ DISCORD_INVITE_CODE             — sudah ada default: qm3XJvRa6B
#  ✅ SORAKU_API_SECRET               — generate random, sama dengan bot
#
#  Isi setelah bot deploy ke Railway:
#  o  BOT_WEBHOOK_URL                 — URL Railway project bot
#  o  BOT_WEBHOOK_SECRET              — sama dengan WEBHOOK_SECRET di bot
#
#  Isi saat fitur payment aktif:
#  o  XENDIT_SECRET_KEY
#  o  XENDIT_WEBHOOK_TOKEN
#  o  TRAKTEER_WEBHOOK_TOKEN
#
# =============================================================================
#
#  SUPABASE AUTH — yang harus diset di Supabase Dashboard:
#  Buka: Supabase → Authentication → URL Configuration
#
#  Site URL:
#    https://soraku.vercel.app
#
#  Redirect URLs (tambahkan semua ini):
#    https://soraku.vercel.app/**
#    https://soraku.vercel.app/api/auth/callback
#    http://localhost:3000/**          ← untuk development lokal
#
#  Tanpa konfigurasi ini → OAuth (Discord/Google) akan error bad_oauth_state
#
# =============================================================================
