# =============================================================================
#  SORAKU COMMUNITY — Web App Environment Variables
#  File    : apps/web/.env.example
#  Copy    : cp apps/web/.env.example apps/web/.env.local
#  Deploy  : Vercel → Project soraku → Settings → Environment Variables
#
#  ⚠  JANGAN commit .env.local ke Git — sudah ada di .gitignore
#  ⚠  Set SKIP_ENV_VALIDATION=true di .env.local jika mau skip validasi T3 Env
#  ⚠  Semua perubahan ENV di Vercel butuh redeploy agar aktif
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# [1] DATABASE  (WAJIB — Drizzle ORM)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string via Supabase Transaction Pooler (port 6543)
# Ambil dari: Supabase → Project Settings → Database → Connection string → URI
# Pilih mode: "Transaction" dan gunakan port 6543
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=


# ─────────────────────────────────────────────────────────────────────────────
# [2] SUPABASE  (WAJIB — Auth + RLS + Storage)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://jrgknsxqwuygcoocnnnb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# [3] URL APLIKASI  (WAJIB)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=https://soraku.vercel.app
NEXT_PUBLIC_APP_URL=https://soraku.vercel.app


# ─────────────────────────────────────────────────────────────────────────────
# [4] XENDIT PAYMENT  (Opsional)
# ─────────────────────────────────────────────────────────────────────────────

XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=


# ─────────────────────────────────────────────────────────────────────────────
