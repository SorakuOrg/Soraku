# =============================================================================
#  SORAKU BOT — Environment Variables
#  Railway → Variables: isi semua yang WAJIB
#  Local  : cp .env.example .env
# =============================================================================

# ─── DISCORD (WAJIB) ──────────────────────────────────────────────────────────

# Bot token — Discord Developer Portal → Bot → Reset Token
TOKEN=

# Application ID — Discord Developer Portal → General Information
CLIENT_ID=

# Server ID Soraku — klik kanan nama server → Copy Server ID
GUILD_ID=

# Channel ID untuk announce event otomatis (opsional)
CHANNEL_ID=


# ─── SUPABASE (WAJIB) ─────────────────────────────────────────────────────────

# Format: https://xxxx.supabase.co
# Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=

# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=


# ─── WEB & WEBHOOK (WAJIB) ────────────────────────────────────────────────────

# URL web Soraku
SORAKU_WEB_URL=https://www.soraku.id

# Secret komunikasi web ↔ bot — harus SAMA dengan BOT_WEBHOOK_SECRET di apps/web
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK=

# Secret untuk services/api — harus SAMA dengan SORAKU_API_SECRET di apps/web
SORAKU_API_SECRET=

# URL services/api (opsional, default pakai SORAKU_WEB_URL)
SORAKU_API_URL=


# ─── OPSIONAL ─────────────────────────────────────────────────────────────────

# Prefix command (default: !)
BOT_PREFIX=!

# Discord ID owner / Riu
OWNER_ID=1020644780075659356

# Role ID tier supporter Discord
ROLE_DONATUR=1436534227708543046
ROLE_VIP=1447194092965728307
ROLE_VVIP=1447194196401459320

# Port HTTP server (Railway auto-set, tidak perlu diisi manual)
PORT=3000


# ─── MUSIK LAVALINK (OPSIONAL) ────────────────────────────────────────────────

LAVA_URL=lava-v4.ajieblogs.eu.org:443
LAVA_AUTH=https://dsc.gg/ajidevserver
LAVA_SECURE=true
LAVA_NAME=Soraku-Lava
SPOTIFY_ID=
SPOTIFY_SECRET=


# =============================================================================
#  RAILWAY CHECKLIST
#
#  WAJIB:  TOKEN  CLIENT_ID  GUILD_ID
#          SUPABASE_URL  SUPABASE_SERVICE_KEY
#          SORAKU_WEB_URL  WEBHOOK  SORAKU_API_SECRET
#
#  SEBELUM ONLINE:
#  1. Run supabase_migration.sql di Supabase SQL Editor
#  2. Discord Dev Portal → Bot → aktifkan:
#     Server Members Intent + Presence Intent + Message Content Intent
#
#  CEK STATUS: https://soraku.up.railway.app/status
# =============================================================================
