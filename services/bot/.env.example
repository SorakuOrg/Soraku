# =============================================================================
#  SORAKU COMMUNITY — Discord Bot Environment Variables
#  File  : services/bot/.env.example
#  Copy  : cp services/bot/.env.example services/bot/.env
#  Deploy: Railway → Variables (masukkan semua ENV di bawah)
#
#  ⚠  JANGAN commit .env ke Git — sudah ada di .gitignore
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# [1] DISCORD BOT  (WAJIB)
# ─────────────────────────────────────────────────────────────────────────────
# Ambil dari: https://discord.com/developers/applications → Bot → Token
# ⚠  Reset token jika sudah pernah expose ke publik
DISCORD_TOKEN=

# ID server Discord Soraku
# Cara ambil: Discord → Server Settings → Widget → Server ID
# Atau klik kanan nama server → Copy Server ID (developer mode harus aktif)
DISCORD_GUILD_ID=

# ID channel untuk announce event otomatis (opsional)
# Klik kanan channel → Copy Channel ID
DISCORD_EVENT_CHANNEL_ID=


# ─────────────────────────────────────────────────────────────────────────────
# [2] KONEKSI KE WEB APP  (WAJIB)
# ─────────────────────────────────────────────────────────────────────────────
# URL web app Soraku yang sudah deploy
# Lokal : http://localhost:3000
# Prod  : https://soraku.vercel.app
SORAKU_API_URL=https://soraku.vercel.app

# Secret untuk auth bot <-> web
# Harus SAMA dengan SORAKU_API_SECRET di apps/web/.env.local
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SORAKU_API_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# [3] WEBHOOK HTTP SERVER  (WAJIB)
# ─────────────────────────────────────────────────────────────────────────────
# Secret untuk verifikasi request yang masuk ke bot dari web
# Harus SAMA dengan BOT_WEBHOOK_SECRET di apps/web/.env.local
WEBHOOK_SECRET=

# Port HTTP server internal bot (Railway auto-assign, opsional lokal)
PORT=3001


# =============================================================================
#  CHECKLIST SEBELUM DEPLOY BOT
# =============================================================================
#
#  Wajib diisi:
#  ✅ DISCORD_TOKEN          — dari Discord Developer Portal
#  ✅ DISCORD_GUILD_ID       — ID server Discord Soraku
#  ✅ SORAKU_API_URL         — URL web app yang sudah deploy
#  ✅ SORAKU_API_SECRET      — harus sama dengan web
#  ✅ WEBHOOK_SECRET         — harus sama dengan BOT_WEBHOOK_SECRET di web
#
#  Opsional:
#  o  DISCORD_EVENT_CHANNEL_ID  — channel untuk announce event
#  o  PORT                      — default 3001, Railway auto-set
#
#  ENV yang perlu di-set di WEB (apps/web/.env.local) agar bot <-> web jalan:
#  BOT_WEBHOOK_URL     = https://<project>.up.railway.app
#  BOT_WEBHOOK_SECRET  = (sama dengan WEBHOOK_SECRET di sini)
#  SORAKU_API_SECRET   = (sama dengan SORAKU_API_SECRET di sini)
#
# =============================================================================
#
#  CARA DEPLOY KE RAILWAY:
#  1. Push ke GitHub
#  2. Railway → New Project → Deploy from GitHub → pilih repo
#  3. Set Root Directory: services/bot
#  4. Masukkan semua ENV di atas di Railway → Variables
#  5. Verifikasi: GET https://<project>.up.railway.app/health
#     Response harus: { "status": "ok" }
#
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# [4] WEB URL & DISCORD CONFIG  (opsional, ada default)
# ─────────────────────────────────────────────────────────────────────────────
# URL web komunitas Soraku (untuk link di embed bot)
# Default: https://soraku.vercel.app
SORAKU_WEB_URL=https://soraku.vercel.app

# Discord invite code (tanpa https://discord.gg/)
# Default: qm3XJvRa6B
DISCORD_INVITE_CODE=qm3XJvRa6B
