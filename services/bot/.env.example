# =============================================================================
#  SORAKU BOT — Environment Variables
#  Copy  : cp .env.example .env
#  Deploy: Railway → Variables (isi semua yang WAJIB)
# =============================================================================

# ─── [1] DISCORD BOT (WAJIB) ─────────────────────────────────────────────────

# Token bot — Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=

# Application ID — Discord Developer Portal → General Information → Application ID
CLIENT_ID=

# Server (Guild) ID Soraku — klik kanan nama server → Copy Server ID
DISCORD_GUILD_ID=


# ─── [2] SUPABASE (WAJIB) ────────────────────────────────────────────────────

# URL project Supabase (sama dengan apps/web)
# Format: https://xxxx.supabase.co
SUPABASE_URL=

# Service Role Key — Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=


# ─── [3] WEB & WEBHOOK (WAJIB) ───────────────────────────────────────────────

# URL web komunitas Soraku yang sudah deploy
SORAKU_WEB_URL=https://www.soraku.id

# Secret untuk komunikasi web ↔ bot
# Harus SAMA dengan BOT_WEBHOOK_SECRET di apps/web
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# URL services/api (untuk /profile dan /event di slash commands)
# Kalau belum ada, pakai SORAKU_WEB_URL saja
SORAKU_API_URL=https://www.soraku.id

# Secret internal untuk API — harus SAMA dengan SORAKU_API_SECRET di apps/web
SORAKU_API_SECRET=


# ─── [4] OPSIONAL ─────────────────────────────────────────────────────────────

# Prefix command (default: !)
BOT_PREFIX=!

# Discord ID owner (Riu) — untuk command !noprefix dan !blacklist
OWNER_ID=1020644780075659356

# Role IDs supporter tier Discord
ROLE_DONATUR=1436534227708543046
ROLE_VIP=1447194092965728307
ROLE_VVIP=1447194196401459320

# Channel ID untuk announce event otomatis
DISCORD_EVENT_CHANNEL_ID=

# Port HTTP server (Railway otomatis set ini, tidak perlu diisi manual)
PORT=3000


# ─── [5] MUSIK LAVALINK (OPSIONAL) ───────────────────────────────────────────
# Kalau tidak diset, musik nonaktif tapi bot tetap jalan

LAVA_URL=lava-v4.ajieblogs.eu.org:443
LAVA_AUTH=https://dsc.gg/ajidevserver
LAVA_SECURE=true
LAVA_NAME=Soraku-Lava

# Spotify integration (opsional)
SPOTIFY_ID=
SPOTIFY_SECRET=


# =============================================================================
#  CHECKLIST DEPLOY RAILWAY
#
#  WAJIB diisi di Railway → Variables:
#  ✅ DISCORD_TOKEN
#  ✅ CLIENT_ID
#  ✅ DISCORD_GUILD_ID
#  ✅ SUPABASE_URL
#  ✅ SUPABASE_SERVICE_ROLE_KEY
#  ✅ SORAKU_WEB_URL
#  ✅ WEBHOOK_SECRET
#  ✅ SORAKU_API_SECRET
#
#  WAJIB dilakukan sebelum bot bisa online:
#  1. Run supabase_migration.sql di Supabase SQL Editor
#  2. Aktifkan di Discord Dev Portal → Bot:
#     - Server Members Intent ✅
#     - Presence Intent ✅
#     - Message Content Intent ✅
#
#  Verifikasi setelah deploy:
#  GET https://soraku.up.railway.app/status
#  → semua env harus "✅ set"
#  → bot harus "🟢 online"
# =============================================================================
