# ============================================================
# SORAKU API SERVICE — Environment Variables
# Copy ke .env.local untuk development
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Supabase Transaction Pooler (port 6543, bukan 5432)
# Format: postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://jrgknsxqwuygcoocnnnb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Secret — auth antar service ───────────────────────────────
# Harus SAMA di: services/api, apps/web, services/bot
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SORAKU_API_SECRET=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated origins yang diizinkan
# Contoh: https://soraku.vercel.app,https://stream.soraku.vercel.app
# Kosongkan = allow all "*" (aman untuk development)
CORS_ORIGINS=

# ── Anime Streaming — Consumet API ────────────────────────────
# Self-host (recommended): docker run -p 3000:3000 ghcr.io/consumet/consumet-api
# Public (rate-limited):   https://api.consumet.org
# Docs: https://docs.consumet.org
CONSUMET_API_URL=https://api.consumet.org

# ── Payment (opsional) ────────────────────────────────────────
XENDIT_SECRET_KEY=
TRAKTEER_WEBHOOK_SECRET=

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=development
