# Supabase
SUPABASE_URL=https://jrgknsxqwuygcoocnnnb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Secret untuk auth antar service (web, bot, mobile)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Harus SAMA dengan SORAKU_API_SECRET di apps/web dan services/bot
SORAKU_API_SECRET=

# Payment (opsional)
XENDIT_SECRET_KEY=
TRAKTEER_WEBHOOK_TOKEN=
