{
  "name": "soraku-community",
  "version": "0.0.1",
  "private": true,
  "description": "Soraku Community — Platform komunitas anime & budaya Jepang Indonesia",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "cd apps/web && pnpm dev",
    "build": "cd apps/web && pnpm install && pnpm build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.8.15",
    "prettier": "^3.5.3",
    "@prettier/plugin-xml": "^3.4.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "next": "^16.1.6"
  }
}
